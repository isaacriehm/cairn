# Harness — secrets only.
# Operator hates env vars; only secrets, brand, and domain go here.
# Hardcoded model IDs and project config belong in code or .harness/config/workflow.md.

# ─── Frontend adapter: Discord ───────────────────────────────────────────────
# Bot token (Discord Developer Portal → Bot → Reset Token)
DISCORD_BOT_TOKEN=

# Guild (server) ID where the bot lives
DISCORD_GUILD_ID=

# Comma-separated owner Discord user-IDs (allowlist for accepted commands)
DISCORD_OWNER_USER_IDS=

# ─── Anthropic (Claude Code primary; harness invokes via SDK + claude CLI) ───
ANTHROPIC_API_KEY=

# ─── OpenAI (Codex secondary, optional) ──────────────────────────────────────
OPENAI_API_KEY=

# ─── Ollama (Tier 0 — local; default install) ────────────────────────────────
OLLAMA_HOST=http://localhost:11434
