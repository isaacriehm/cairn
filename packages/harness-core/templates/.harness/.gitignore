# Per-session state — owned by exactly one Claude Code session.
# Created at SessionStart, removed at SessionEnd, GC'd if stale.
sessions/

# Invalidation event log — inter-session signal, 7-day retention,
# regenerable. Spec: PLUGIN_ARCHITECTURE §7.
events/

# Per-write flock + whole-operation locks (per PLUGIN_ARCHITECTURE §7).
.write-lock
.gc-lock
.audit-lock

# Per-clone attested-commits log — written by post-commit hook, read by
# Stop hook bypass detection. Per PLUGIN_ARCHITECTURE §17 Layer 1.
.attested-commits
