#!/usr/bin/env bash
# Cairn pre-commit hook (versioned, per-clone activation via core.hooksPath).
#
# Runs two passes against the staged tree:
#
#   1. `cairn sensor-run --staged`      — sensor-driven enforcement
#                                         (may exit non-zero, blocking
#                                         the commit when a configured
#                                         sensor's trigger fires).
#
#   2. `cairn hook pre-commit-align`    — Layer B (plan §4.2)
#                                         detection-only SoT drift log.
#                                         NEVER blocks the commit.
#                                         Always exits 0; failures
#                                         degrade silently.
#
# Resolution order for the cairn binary:
#   1. .cairn/.cli-path (written by `cairn join`; points at the bundled
#      cli.mjs for plugin users, the global cairn shim for CLI users).
#   2. global `cairn` binary on PATH.
#   3. exit 0 — no enforcement available; SessionStart bootstrap banner
#      will surface on next Claude Code session and re-run join.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel 2> /dev/null || true)"
if [ -z "$REPO_ROOT" ] || [ ! -d "$REPO_ROOT/.cairn" ]; then
  exit 0
fi

CAIRN_CMD=""
if [ -f "$REPO_ROOT/.cairn/.cli-path" ]; then
  CAIRN_CMD="$(head -n1 "$REPO_ROOT/.cairn/.cli-path")"
fi
if [ -z "$CAIRN_CMD" ] && command -v cairn > /dev/null 2>&1; then
  CAIRN_CMD="cairn"
fi
if [ -z "$CAIRN_CMD" ]; then
  exit 0
fi

# Pass 1 — sensor-run (may block).
eval "$CAIRN_CMD sensor-run --staged"

# Pass 2 — Layer B alignment log (never blocks).
eval "$CAIRN_CMD hook pre-commit-align" || true
