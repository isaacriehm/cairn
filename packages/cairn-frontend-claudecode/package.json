{
  "name": "@isaacriehm/cairn-frontend-claudecode",
  "version": "0.2.0",
  "description": "Claude Code plugin frontend for Cairn — invisible project maintainer.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "files": [
    ".claude-plugin",
    ".mcp.json",
    "hooks",
    "skills",
    "agents",
    "commands",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/check-layout.mjs && node scripts/build-bundle.mjs",
    "typecheck": "node scripts/check-layout.mjs",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@isaacriehm/cairn": "workspace:*",
    "@isaacriehm/cairn-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.0"
  }
}
