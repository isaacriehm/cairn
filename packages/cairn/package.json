{
  "name": "@isaacriehm/cairn",
  "version": "0.7.1",
  "description": "Cairn — state + context-loading layer for AI coding agents.",
  "author": "Isaac Riehm",
  "license": "MIT",
  "homepage": "https://github.com/isaacriehm/cairn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacriehm/cairn.git"
  },
  "bugs": {
    "url": "https://github.com/isaacriehm/cairn/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "cairn": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsx src/cli/index.ts",
    "check:layout": "tsx scripts/check-layout.ts",
    "smoke:gc": "tsx scripts/smoke-gc.ts",
    "smoke:init": "tsx scripts/smoke-init.ts",
    "smoke:session-start": "tsx scripts/smoke-session-start.ts",
    "smoke:status-line": "tsx scripts/smoke-status-line.ts",
    "smoke:handoff": "tsx scripts/smoke-handoff.ts",
    "smoke:scope-index": "tsx scripts/smoke-scope-index.ts",
    "smoke:read-enrich": "tsx scripts/smoke-read-enrich.ts",
    "smoke:ingestion-baseline": "tsx scripts/smoke-ingestion-baseline.ts",
    "smoke:lock": "tsx scripts/smoke-lock.ts",
    "smoke:session-state": "tsx scripts/smoke-session-state.ts",
    "smoke:events": "tsx scripts/smoke-events.ts",
    "smoke:plugin-layout": "tsx scripts/smoke-plugin-layout.ts",
    "smoke:resolve-attention": "tsx scripts/smoke-resolve-attention.ts",
    "smoke:stop-hook": "tsx scripts/smoke-stop-hook.ts",
    "smoke:source-comments": "tsx scripts/smoke-source-comments.ts",
    "smoke:rules-merge": "tsx scripts/smoke-rules-merge.ts",
    "smoke:join": "tsx scripts/smoke-join.ts",
    "smoke:bypass-detection": "tsx scripts/smoke-bypass-detection.ts",
    "smoke:bootstrap-guard": "tsx scripts/smoke-bootstrap-guard.ts",
    "smoke:e2e-adoption": "tsx scripts/smoke-e2e-adoption.ts",
    "smoke:e2e-daily-flow": "tsx scripts/smoke-e2e-daily-flow.ts",
    "smoke:plugin-bundle": "tsx scripts/smoke-plugin-bundle.ts",
    "smoke:init-phases-state": "tsx scripts/smoke-init-phases-state.ts",
    "smoke:init-phases-all": "tsx scripts/smoke-init-phases-all.ts",
    "smoke:init-mcp-tools": "tsx scripts/smoke-init-mcp-tools.ts",
    "smoke:init-progress-heartbeat": "tsx scripts/smoke-init-progress-heartbeat.ts",
    "smoke:stop-debounce": "tsx scripts/smoke-stop-debounce.ts",
    "smoke:id-content-addressed": "tsx scripts/smoke-id-content-addressed.ts",
    "smoke:attention-serve": "tsx scripts/smoke-attention-serve.ts",
    "smoke:topic-index": "tsx scripts/smoke-topic-index.ts",
    "smoke:search-candidates": "tsx scripts/smoke-search-candidates.ts",
    "smoke:propose-decision": "tsx scripts/smoke-propose-decision.ts",
    "smoke:reject-candidate": "tsx scripts/smoke-reject-candidate.ts",
    "smoke:tag-cli": "tsx scripts/smoke-tag-cli.ts",
    "smoke:llm-prompt-eval": "tsx scripts/smoke-llm-prompt-eval.ts",
    "smoke:conflicts-queue": "tsx scripts/smoke-conflicts-queue.ts",
    "smoke:sot-align": "tsx scripts/smoke-sot-align.ts",
    "smoke:layer-b-precommit": "tsx scripts/smoke-layer-b-precommit.ts",
    "smoke:layer-c-sessionstart-drain": "tsx scripts/smoke-layer-c-sessionstart-drain.ts",
    "smoke:fix-align": "tsx scripts/smoke-fix-align.ts",
    "smoke:fix-align-gates": "tsx scripts/smoke-fix-align-gates.ts",
    "smoke:attention-undo": "tsx scripts/smoke-attention-undo.ts",
    "smokes": "pnpm smoke:plugin-layout && pnpm smoke:resolve-attention && pnpm smoke:stop-hook && pnpm smoke:events && pnpm smoke:session-state && pnpm smoke:status-line && pnpm smoke:session-start && pnpm smoke:handoff && pnpm smoke:scope-index && pnpm smoke:read-enrich && pnpm smoke:init && pnpm smoke:ingestion-baseline && pnpm smoke:gc && pnpm smoke:lock && pnpm smoke:source-comments && pnpm smoke:rules-merge && pnpm smoke:join && pnpm smoke:bypass-detection && pnpm smoke:bootstrap-guard && pnpm smoke:e2e-adoption && pnpm smoke:e2e-daily-flow && pnpm smoke:plugin-bundle && pnpm smoke:init-phases-state && pnpm smoke:init-phases-all && pnpm smoke:init-mcp-tools && pnpm smoke:init-progress-heartbeat && pnpm smoke:stop-debounce",
    "smokes:all": "pnpm run \"/^smoke:/\""
  },
  "dependencies": {
    "@isaacriehm/cairn-core": "workspace:*",
    "simple-git": "^3.36.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
