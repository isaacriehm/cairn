{
  "name": "cairn-lens",
  "displayName": "Cairn Lens",
  "description": "Inline citation context for §INV invariants and TODO(TSK-) tokens. Hovers, gutter icons, code lens — resolved from .cairn/ground/ ledgers.",
  "version": "0.7.1",
  "publisher": "isaacriehm",
  "type": "module",
  "engines": {
    "node": ">=22",
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:cairn-lens.showLog",
    "onCommand:cairn-lens.diagnose",
    "onCommand:cairn-lens.refresh",
    "onCommand:cairn-lens.openDecisionsLedger",
    "onCommand:cairn-lens.openInvariantsLedger"
  ],
  "contributes": {
    "configuration": {
      "title": "Cairn Lens",
      "properties": {
        "cairn.lens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master switch for Cairn Lens features."
        },
        "cairn.lens.inlineDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Render ghost text after §INV-NNNN tokens with the resolved invariant title."
        },
        "cairn.lens.gutterIcons": {
          "type": "boolean",
          "default": true,
          "description": "Show citation health icons in the gutter (active / superseded / not found)."
        },
        "cairn.lens.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Render a Code Lens line above functions whose file matches a decision's scope_globs."
        },
        "cairn.lens.decExplorer": {
          "type": "boolean",
          "default": false,
          "description": "Show the DEC Explorer sidebar tree view."
        },
        "cairn.lens.inlineMode": {
          "type": "string",
          "default": "ghost",
          "enum": [
            "ghost",
            "replace",
            "below",
            "off"
          ],
          "enumDescriptions": [
            "Ghost text appended after the token (default).",
            "Replace the rest of the comment line after the token with the resolved title.",
            "Insert the resolved title on a separate line below the token.",
            "Disable inline display entirely."
          ],
          "description": "Controls how resolved titles are displayed inline."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "cairnLens.decExplorer",
          "name": "Cairn DEC Explorer",
          "when": "config.cairn.lens.decExplorer && config.cairn.lens.enabled"
        }
      ]
    },
    "commands": [
      {
        "command": "cairn-lens.showLog",
        "title": "Show Debug Log",
        "category": "Cairn"
      },
      {
        "command": "cairn-lens.diagnose",
        "title": "Diagnose",
        "category": "Cairn"
      },
      {
        "command": "cairn-lens.refresh",
        "title": "Refresh All Decorations",
        "category": "Cairn"
      },
      {
        "command": "cairn-lens.openDecisionsLedger",
        "title": "Open Decisions Ledger",
        "category": "Cairn"
      },
      {
        "command": "cairn-lens.openInvariantsLedger",
        "title": "Open Invariants Ledger",
        "category": "Cairn"
      }
    ]
  },
  "license": "MIT",
  "author": "Isaac Riehm",
  "homepage": "https://github.com/isaacriehm/cairn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacriehm/cairn.git"
  },
  "bugs": {
    "url": "https://github.com/isaacriehm/cairn/issues"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo *.vsix",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/extension.cjs --external:vscode --external:fsevents --define:__CAIRN_BUNDLED__=false --banner:js=\"const __filename_polyfill=require('path').join(__dirname,'extension.cjs');const __cairn_meta_url=require('url').pathToFileURL(__filename_polyfill).href;\" --define:import.meta.url=__cairn_meta_url",
    "package": "pnpm clean && pnpm build && pnpm bundle && vsce package --no-dependencies",
    "smoke:resolver": "tsx scripts/smoke-resolver.ts",
    "smoke:dec-tokens": "tsx scripts/smoke-dec-tokens.ts",
    "smoke:empty-ground": "tsx scripts/smoke-empty-ground.ts",
    "smoke:sot-body": "tsx scripts/smoke-sot-body.ts",
    "smoke:staleness": "tsx scripts/smoke-staleness.ts"
  },
  "dependencies": {
    "@isaacriehm/cairn-state": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
