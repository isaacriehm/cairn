{
  "name": "@devplusllc/harness",
  "version": "0.0.0",
  "description": "Portable agent harness — Discord-front-ended, filesystem-state, honest-agent invariants stack.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "harness": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsx src/cli/index.ts",
    "check:layout": "tsx scripts/check-layout.ts",
    "smoke:mcp": "tsx scripts/smoke-mcp.ts",
    "smoke:whisper": "tsx scripts/smoke-whisper.ts",
    "smoke:tier0": "tsx scripts/smoke-tier0.ts",
    "smoke:tightener": "tsx scripts/smoke-tightener.ts",
    "smoke:sensors": "tsx scripts/smoke-sensors.ts",
    "smoke:gc": "tsx scripts/smoke-gc.ts",
    "smoke:decision-capture": "tsx scripts/smoke-decision-capture.ts",
    "smoke:decision-refinement": "tsx scripts/smoke-decision-refinement.ts",
    "smoke:init": "tsx scripts/smoke-init.ts",
    "smoke:init-mapper": "tsx scripts/smoke-init-mapper.ts",
    "smoke:module-slicer": "tsx scripts/smoke-module-slicer.ts",
    "smoke:steering": "tsx scripts/smoke-steering.ts",
    "smoke:visibility": "tsx scripts/smoke-visibility.ts",
    "smoke:ux-cleanups": "tsx scripts/smoke-ux-cleanups.ts",
    "smoke:quota-archive": "tsx scripts/smoke-quota-archive.ts",
    "smoke:cli-extras": "tsx scripts/smoke-cli-extras.ts",
    "smoke:session-start": "tsx scripts/smoke-session-start.ts",
    "smoke:query-history": "tsx scripts/smoke-query-history.ts",
    "smoke:status-line": "tsx scripts/smoke-status-line.ts",
    "smoke:handoff": "tsx scripts/smoke-handoff.ts",
    "smoke:scope-index": "tsx scripts/smoke-scope-index.ts",
    "smoke:read-enrich": "tsx scripts/smoke-read-enrich.ts",
    "smoke:ingestion-baseline": "tsx scripts/smoke-ingestion-baseline.ts",
    "setup:mirror": "tsx scripts/setup-mirror.ts",
    "setup:whisper": "tsx scripts/setup-whisper.ts",
    "setup:uat-browsers": "tsx scripts/setup-uat-browsers.ts",
    "setup:uat-sql": "tsx scripts/setup-uat-sql.ts",
    "setup:uat-docker": "tsx scripts/setup-uat-docker.ts",
    "smoke:lock": "tsx scripts/smoke-lock.ts",
    "smoke:session-state": "tsx scripts/smoke-session-state.ts",
    "smoke:events": "tsx scripts/smoke-events.ts",
    "smoke:plugin-layout": "tsx scripts/smoke-plugin-layout.ts",
    "smoke:resolve-attention": "tsx scripts/smoke-resolve-attention.ts",
    "smoke:stop-hook": "tsx scripts/smoke-stop-hook.ts"
  },
  "dependencies": {
    "@devplusllc/harness-core": "workspace:*",
    "@devplusllc/harness-frontend-stub": "workspace:*",
    "dotenv": "^17.4.2",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.1",
    "playwright-core": "^1.50.0",
    "simple-git": "^3.36.0",
    "smart-whisper": "^0.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
